# Copy to /srv/ProfitsNLosses/.env and fill real values on the server.
# Do not commit the real .env file.

# Google Sheets is required only for the Situations page.
GOOGLE_SHEETS_CREDENTIALS_PATH=backend/google-service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SITUATIONS_SHEET=Situations

# Portal database used for local/private backend startup and legacy row ownership.
# Runtime Portal requests identify users through X-Portal-User-Id headers.
PNL_PORTAL_DB_PATH=/srv/SoftPortal/backend/data/portal.db

# Must exist in SoftPortal before the first ProfitsNLosses backend start.
# For a fresh server this can be admin, or your own portal username if you create it first.
PNL_DEV_USERNAME=admin

# Optional hard override. Leave empty if username lookup should be used.
PNL_DEV_USER_ID=

# One-time owner for old local rows created before portal users existed.
# Set only if you migrate an old profits_n_losses.sqlite3 and need a specific owner.
PNL_LEGACY_OWNER_USERNAME=
PNL_LEGACY_OWNER_USER_ID=
