# Copy this file to .env and fill local values.

# Path can be absolute, or relative to project root / backend directory.
GOOGLE_SHEETS_CREDENTIALS_PATH=backend/google-service-account.json

# Do not commit the real sheet id in public repositories.
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheet_id_here

# Sheet tab used by the Situations page.
GOOGLE_SHEETS_SITUATIONS_SHEET=Situations
